<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:KuranMealApp.ViewModels"
             x:Class="KuranMealApp.Views.FihristPage"
             x:DataType="viewmodels:FihristViewModel"
             Title="Fihrist"
             BackgroundColor="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" Padding="16,20,16,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24" />
            </Border.StrokeShape>
            
            <VerticalStackLayout Spacing="12">
                <Label Text="Konu Fihristi"
                       Style="{StaticResource HeadlineMedium}"
                       TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}"
                       FontAttributes="Bold" />
                <Label Text="Kur'an-ı Kerim'de geçen konulara göre ayetleri keşfedin."
                       Style="{StaticResource BodyMedium}"
                       TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}" />
            </VerticalStackLayout>
        </Border>

        <CollectionView Grid.Row="1" Margin="16" ItemsSource="{Binding Konular}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodels:FihristKonu">
                    <Border Style="{StaticResource ElevatedCard}" Padding="16" Margin="0,0,0,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BindingContext.KonuSecildiCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="16">
                            <Label Grid.Column="0" Text="{Binding İkon}" FontSize="32" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding Baslik}" FontAttributes="Bold" FontSize="18" FontFamily="{DynamicResource AppFontFamily}" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                                <Label Text="{Binding Aciklama}" Style="{StaticResource BodyMedium}" FontFamily="{DynamicResource AppFontFamily}" TextColor="{StaticResource MD3TextSecondary}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="▶" VerticalOptions="Center" TextColor="{StaticResource MD3TextSecondary}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
