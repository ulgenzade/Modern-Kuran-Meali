<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KuranMealApp.ViewModels"
             xmlns:models="clr-namespace:KuranMealApp.Models"
             x:Class="KuranMealApp.Views.AyetlerPage"
             x:DataType="vm:AyetlerViewModel"
             x:Name="page"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,Auto,*" Margin="0">

        <Border Grid.Row="0" StrokeThickness="0" Padding="16,10,16,12" Background="{AppThemeBinding Light=#F9F6EE, Dark={StaticResource MD3SurfaceVariantDark}}" ZIndex="5">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,0,0"/></Border.StrokeShape>
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="4">
                <Button Grid.Column="0"
                        Text="← Geri"
                        Style="{StaticResource TonalButton}"
                        FontSize="14"
                        FontAttributes="Bold"
                        Padding="12,0"
                        Clicked="OnBackClicked" />

                <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                    <Border StrokeThickness="0" Background="Transparent" Padding="8,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleSurePickerCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding SureName}"
                                   TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}"
                                   FontSize="18"
                                   FontAttributes="Bold" />
                            <Label Text="▾" TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}" VerticalOptions="Center" FontSize="14" />
                        </HorizontalStackLayout>
                    </Border>
                    
                    <Border StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" Padding="8,4">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleAyetPickerCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="4" VerticalOptions="Center">
                            <Label Text="{Binding CurrentAyetNo, StringFormat='Ayet {0}'}"
                                   TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}"
                                   FontSize="14"
                                   FontAttributes="Bold" />
                            <Label Text="▾" TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}" VerticalOptions="Center" FontSize="12" />
                        </HorizontalStackLayout>
                    </Border>
                </HorizontalStackLayout>


            </Grid>
        </Border>

        <Border Grid.Row="1" StrokeThickness="0" Background="{AppThemeBinding Light=#F9F6EE, Dark={StaticResource MD3SurfaceVariantDark}}" Padding="16,0,16,12" ZIndex="5">
            <Border.StrokeShape><RoundRectangle CornerRadius="0,0,16,16"/></Border.StrokeShape>
            <Border.Shadow><Shadow Brush="Black" Opacity="0.15" Offset="0,4" Radius="8"/></Border.Shadow>
            <VerticalStackLayout Spacing="12">
                
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Button Grid.Column="0" 
                            Text="{Binding DarkModeButtonText}"
                            Command="{Binding ToggleDarkModeCommand}"
                            Style="{StaticResource TonalButton}"
                            HorizontalOptions="Start" />
                    <Border Grid.Column="2" StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" Padding="12,6" VerticalOptions="Center">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16" /></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ToggleFilterSheetCommand}" Tapped="OnToggleOptionTapped" />
                        </Border.GestureRecognizers>
                        <Label Text="☰ Tefsirler" VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3TextPrimaryDark}}" FontAttributes="Bold" FontSize="14" />
                    </Border>
                </Grid>
                
                <Grid ColumnDefinitions="*,*">
                    <Border Grid.Column="0" StrokeThickness="0" Background="{AppThemeBinding Light=#FFFFFF, Dark={StaticResource MD3SurfaceDark}}" Padding="4" Margin="0,0,8,0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                        <Grid ColumnDefinitions="*,*">
                            <Border Grid.Column="0" StrokeThickness="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding UseHorizontalReadingMode}" Value="False">
                                                <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3Primary}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SetReadingModeCommand}" CommandParameter="Dikey" Tapped="OnToggleOptionTapped" /></Border.GestureRecognizers>
                                <Label Text="Dikey" HorizontalOptions="Center" VerticalOptions="Center" Padding="0,8" FontAttributes="Bold">
                                    <Label.Style>
                                        <Style TargetType="Label">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3TextSecondary}, Dark={StaticResource MD3TextSecondaryDark}}" />
                                            <Style.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding UseHorizontalReadingMode}" Value="False">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnPrimary}}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                            </Border>
                            <Border Grid.Column="1" StrokeThickness="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding UseHorizontalReadingMode}" Value="True">
                                                <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3Primary}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                                <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SetReadingModeCommand}" CommandParameter="Yatay" Tapped="OnToggleOptionTapped" /></Border.GestureRecognizers>
                                <Label Text="Yatay" HorizontalOptions="Center" VerticalOptions="Center" Padding="0,8" FontAttributes="Bold">
                                    <Label.Style>
                                        <Style TargetType="Label">
                                            <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3TextSecondary}, Dark={StaticResource MD3TextSecondaryDark}}" />
                                            <Style.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding UseHorizontalReadingMode}" Value="True">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnPrimary}}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Label.Style>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>
                
                <Border Grid.Column="1" StrokeThickness="0" Background="{AppThemeBinding Light=#FFFFFF, Dark={StaticResource MD3SurfaceDark}}" Padding="4" Margin="8,0,0,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                    <Grid ColumnDefinitions="*,*">
                        <Border Grid.Column="0" StrokeThickness="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsKlasikSira}" Value="True">
                                            <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3Primary}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SetSiralamaCommand}" CommandParameter="Klasik" Tapped="OnToggleOptionTapped" /></Border.GestureRecognizers>
                            <Label Text="Klasik" HorizontalOptions="Center" VerticalOptions="Center" Padding="0,8" FontAttributes="Bold" InputTransparent="False">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetSiralamaCommand}" CommandParameter="Klasik" Tapped="OnToggleOptionTapped" />
                                </Label.GestureRecognizers>
                                <Label.Style>
                                    <Style TargetType="Label">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3TextSecondary}, Dark={StaticResource MD3TextSecondaryDark}}" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsKlasikSira}" Value="True">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnPrimary}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                    </Label.Style>
                                </Label>
                            </Border>
                            <Border Grid.Column="1" StrokeThickness="0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsKlasikSira}" Value="False">
                                            <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3Primary}}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                            <Border.GestureRecognizers><TapGestureRecognizer Command="{Binding SetSiralamaCommand}" CommandParameter="Inis" Tapped="OnToggleOptionTapped" /></Border.GestureRecognizers>
                            <Label Text="İniş" HorizontalOptions="Center" VerticalOptions="Center" Padding="0,8" FontAttributes="Bold" InputTransparent="False">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SetSiralamaCommand}" CommandParameter="Inis" Tapped="OnToggleOptionTapped" />
                                </Label.GestureRecognizers>
                                <Label.Style>
                                    <Style TargetType="Label">
                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3TextSecondary}, Dark={StaticResource MD3TextSecondaryDark}}" />
                                        <Style.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsKlasikSira}" Value="False">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnPrimary}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Label.Style>
                            </Label>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </VerticalStackLayout>
        </Border>

        <Grid Grid.Row="2">

            <Grid IsVisible="{Binding IsBusy}"
                  InputTransparent="False"
                  ZIndex="100"
                  BackgroundColor="{AppThemeBinding Light=#CCF9F6EE, Dark=#CC111827}">
                <Grid.GestureRecognizers><TapGestureRecognizer /></Grid.GestureRecognizers>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="16">
                    <ActivityIndicator IsRunning="True"
                                       Color="{StaticResource MD3Primary}"
                                       WidthRequest="48"
                                       HeightRequest="48" />
                    <Label Text="{Binding LoadingMessage}"
                            Style="{StaticResource BodyMedium}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <CollectionView x:Name="AyetListView"
                            ItemsSource="{Binding AyetGroups}"
                            IsGrouped="True"
                            IsVisible="{Binding IsVerticalMode}"
                            Margin="16,0,16,16"
                            Scrolled="AyetListView_Scrolled"
                            VerticalScrollBarVisibility="Never"
                            ItemSizingStrategy="MeasureAllItems">

                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="vm:SureGroup">
                        <BoxView HeightRequest="4" Color="Transparent" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AyetItem">
                        <Border Style="{StaticResource ElevatedCard}" Padding="16,16,16,12" Margin="0,4,0,10">
                            <VerticalStackLayout Spacing="12" CompressedLayout.IsHeadless="True">
                                
                                <Border StrokeThickness="0" Background="{StaticResource MD3PrimaryContainer}" HorizontalOptions="Start" Padding="10,4">
                                    <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                    <Label Text="{Binding AyetNo, StringFormat='{0}. Ayet', Mode=OneTime}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MD3OnPrimaryContainer}" />
                                </Border>

                                <Label Text="{Binding ArapcaMetin, Mode=OneTime}"
                                       LineBreakMode="WordWrap"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="ArabicMushaf"
                                       FontSize="{Binding BindingContext.ArabicFontSize, Source={x:Reference page}}"
                                       TextColor="{AppThemeBinding Light={StaticResource ArabicTextColor}, Dark={StaticResource ArabicTextColorDark}}" />

                                <Label Text="{Binding Transkript, Mode=OneTime}"
                                       FontAttributes="Italic"
                                       HorizontalTextAlignment="Center"
                                       FontFamily="{DynamicResource AppFontFamily}"
                                       FontSize="{Binding BindingContext.TranscriptFontSize, Source={x:Reference page}}"
                                       TextColor="{StaticResource TranscriptColor}" />

                                     <BoxView HeightRequest="1" Color="{StaticResource MD3Outline}" Margin="0,4" />

                                 <StackLayout BindableLayout.ItemsSource="{Binding Mealler}" Spacing="12" CompressedLayout.IsHeadless="True">
                                     <BindableLayout.ItemTemplate>
                                         <DataTemplate x:DataType="models:MealWithAciklama">
                                             <VerticalStackLayout Spacing="4" CompressedLayout.IsHeadless="True">
                                 <Label FontFamily="{DynamicResource AppFontFamily}"
                                       FontSize="{Binding BindingContext.MealFontSize, Source={x:Reference page}}"
                                                       TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}"
                                                       LineBreakMode="WordWrap">
                                                    <Label.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding BindingContext.ToggleAciklamaCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" />
                                                    </Label.GestureRecognizers>
                                                    <Label.FormattedText>
                                                        <FormattedString>
                                                            <Span Text="{Binding DisplayYazarAdi, Mode=OneTime}" FontAttributes="Bold" FontFamily="{DynamicResource AppFontFamily}" />
                                                            <Span Text="{Binding MealMetni, Mode=OneTime}" FontFamily="{DynamicResource AppFontFamily}" />
                                                        </FormattedString>
                                                     </Label.FormattedText>
                                                 </Label>

                                                 <Border IsVisible="{Binding IsAciklamaExpanded}"
                                                        StrokeThickness="0"
                                                        Background="{StaticResource MD3SecondaryContainer}"
                                                        Padding="12,10"
                                                        Margin="0,4,0,0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="8" />
                                                    </Border.StrokeShape>
                                                    <VerticalStackLayout Spacing="6" CompressedLayout.IsHeadless="True">
                                <HorizontalStackLayout Spacing="6" CompressedLayout.IsHeadless="True">
                                    <Label Text="📖" FontSize="13" VerticalOptions="Center" />
                                    <Label Text="{Binding YazarAdi, StringFormat='{0} Açıklaması', Mode=OneTime}"
                                           FontFamily="{DynamicResource AppFontFamily}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource MD3OnSecondaryContainer}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                 <Label Text="{Binding AciklamaMetni, Mode=OneTime}"
                                        FontFamily="{DynamicResource AppFontFamily}"
                                        FontSize="{Binding BindingContext.AciklamaFontSize, Source={x:Reference page}}"
                                        TextColor="{StaticResource MD3OnSecondaryContainer}"
                                        LineBreakMode="WordWrap" />
                                                     </VerticalStackLayout>
                                                 </Border>
                                             </VerticalStackLayout>
                                         </DataTemplate>
                                     </BindableLayout.ItemTemplate>
                                 </StackLayout>

                                 <Border IsVisible="{Binding IsNuzulExpanded}"
                                        StrokeThickness="0"
                                        Background="{StaticResource MD3PrimaryContainer}"
                                        Padding="14,10"
                                        Margin="0,4,0,0">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8" />
                                    </Border.StrokeShape>
                                    <VerticalStackLayout Spacing="6" CompressedLayout.IsHeadless="True">
                                        <HorizontalStackLayout Spacing="6" CompressedLayout.IsHeadless="True">
                                            <Label Text="🌙" FontSize="13" VerticalOptions="Center" />
                                            <Label Text="İniş Sebebi (Esbab-ı Nüzul)"
                                                   FontSize="11"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource MD3OnPrimaryContainer}"
                                                   VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                  <Label Text="{Binding NuzulSebebiText, Mode=OneTime}"
                                        FontFamily="{DynamicResource AppFontFamily}"
                                        FontSize="13"
                                        TextColor="{StaticResource MD3OnPrimaryContainer}"
                                        LineBreakMode="WordWrap" />
                                     </VerticalStackLayout>
                                 </Border>

                                 <VerticalStackLayout Margin="0,8,0,0" CompressedLayout.IsHeadless="True">
                                     <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Center" AlignItems="Center">
                                         
                                         <Border IsVisible="{Binding HasNuzulSebebi, Mode=OneTime}" Stroke="{StaticResource MD3Outline}" StrokeThickness="1" Background="Transparent" Padding="12,8" Margin="4">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.ShowNuzulPopupCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" Tapped="OnPillButtonTapped" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center" CompressedLayout.IsHeadless="True">
                                                <Label Text="ℹ️" FontSize="14" VerticalOptions="Center" />
                                                <Label Text="Nüzul Sebebi" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" VerticalOptions="Center" />
                                             </HorizontalStackLayout>
                                         </Border>

                                         <Border IsVisible="{Binding HasTefsir, Mode=OneTime}" Stroke="{StaticResource MD3Outline}" StrokeThickness="1" Background="Transparent" Padding="12,8" Margin="4">
                                            <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding BindingContext.ShowTefsirPopupCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" Tapped="OnPillButtonTapped" />
                                            </Border.GestureRecognizers>
                                            <HorizontalStackLayout Spacing="6" VerticalOptions="Center" CompressedLayout.IsHeadless="True">
                                                <Label Text="📖" FontSize="14" VerticalOptions="Center" />
                                                <Label Text="Tefsir" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                        
                                    </FlexLayout>
                                </VerticalStackLayout>

                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                 </CollectionView.ItemTemplate>

                 <CollectionView.Footer>
                    <BoxView HeightRequest="80" Color="Transparent" />
                 </CollectionView.Footer>
             </CollectionView>

             <Grid x:Name="AyetScrollTrackGrid" 
                  WidthRequest="48" 
                  HorizontalOptions="End" 
                  Margin="0,8,0,90"
                  BackgroundColor="Transparent"
                  IsVisible="{Binding IsVerticalMode}"
                  ZIndex="11">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnAyetScrollTrackTapped" />
                     <PanGestureRecognizer PanUpdated="OnAyetScrollThumbPan" />
                 </Grid.GestureRecognizers>
                 
                 <BoxView WidthRequest="3" 
                         CornerRadius="1.5" 
                         BackgroundColor="{AppThemeBinding Light=#E0DCD3, Dark=#404040}" 
                         HorizontalOptions="Center" 
                          VerticalOptions="Fill"
                          InputTransparent="True" />
                          
                 <Grid x:Name="AyetScrollThumbGrid" 
                      HeightRequest="60" 
                      VerticalOptions="Start"
                       HorizontalOptions="Fill"
                       BackgroundColor="Transparent"
                       Opacity="0.8">
                     <Border WidthRequest="14" 
                            HeightRequest="60" 
                            BackgroundColor="{AppThemeBinding Light=#2B604B, Dark={StaticResource MD3Primary}}" 
                            HorizontalOptions="Center" 
                            VerticalOptions="Center"
                            InputTransparent="True">
                        <Border.StrokeShape><RoundRectangle CornerRadius="7"/></Border.StrokeShape>
                    </Border>
                 </Grid>
             </Grid>

             <CarouselView x:Name="AyetCarouselView"
                          ItemsSource="{Binding FlatAyetler}"
                          IsVisible="{Binding IsHorizontalMode}"
                          CurrentItemChanged="OnCarouselCurrentItemChanged"
                          PeekAreaInsets="0">
                 <CarouselView.ItemTemplate>
                     <DataTemplate x:DataType="models:AyetItem">
                         <ScrollView Padding="16">
                             <Border Style="{StaticResource ElevatedCard}" Padding="16,16,16,12">
                                 <VerticalStackLayout Spacing="12">
                                     <Border StrokeThickness="0" Background="{StaticResource MD3PrimaryContainer}" HorizontalOptions="Start" Padding="10,4">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                        <Label Text="{Binding AyetNo, StringFormat='{0}. Ayet'}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource MD3OnPrimaryContainer}" />
                                    </Border>
                                    
                                    <Label Text="{Binding ArapcaMetin}" LineBreakMode="WordWrap" HorizontalTextAlignment="Center" FontFamily="ArabicMushaf" FontSize="{Binding BindingContext.ArabicFontSize, Source={x:Reference page}}" TextColor="{AppThemeBinding Light={StaticResource ArabicTextColor}, Dark={StaticResource ArabicTextColorDark}}" />
                                    <Label Text="{Binding Transkript}" FontAttributes="Italic" HorizontalTextAlignment="Center" FontFamily="{DynamicResource AppFontFamily}" FontSize="{Binding BindingContext.TranscriptFontSize, Source={x:Reference page}}" TextColor="{StaticResource TranscriptColor}" />
                                    <BoxView HeightRequest="1" Color="{StaticResource MD3Outline}" Margin="0,4" />
                                    <StackLayout BindableLayout.ItemsSource="{Binding Mealler}" Spacing="12">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:MealWithAciklama">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label FontFamily="{DynamicResource AppFontFamily}" FontSize="{Binding BindingContext.MealFontSize, Source={x:Reference page}}" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" LineBreakMode="WordWrap">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Command="{Binding BindingContext.ToggleAciklamaCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" />
                                                        </Label.GestureRecognizers>
                                                        <Label.FormattedText>
                                                            <FormattedString>
                                                                <Span Text="{Binding DisplayYazarAdi}" FontAttributes="Bold" FontFamily="{DynamicResource AppFontFamily}" />
                                                                <Span Text="{Binding MealMetni}" FontFamily="{DynamicResource AppFontFamily}" />
                                                            </FormattedString>
                                                        </Label.FormattedText>
                                                    </Label>
                                                    <Border IsVisible="{Binding IsAciklamaExpanded}" StrokeThickness="0" Background="{StaticResource MD3SecondaryContainer}" Padding="12,10" Margin="0,4,0,0">
                                                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                                        <VerticalStackLayout Spacing="6">
                                                            <Label Text="{Binding AciklamaMetni}" FontFamily="{DynamicResource AppFontFamily}" FontSize="{Binding BindingContext.AciklamaFontSize, Source={x:Reference page}}" TextColor="{StaticResource MD3OnSecondaryContainer}" LineBreakMode="WordWrap" />
                                                        </VerticalStackLayout>
                                                    </Border>
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </StackLayout>
                                    <Border IsVisible="{Binding IsNuzulExpanded}" StrokeThickness="0" Background="{StaticResource MD3PrimaryContainer}" Padding="14,10" Margin="0,4,0,0">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                                        <VerticalStackLayout Spacing="6">
                                            <Label Text="{Binding NuzulSebebiText}" FontFamily="{DynamicResource AppFontFamily}" FontSize="13" TextColor="{StaticResource MD3OnPrimaryContainer}" LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </Border>
                                     <VerticalStackLayout Margin="0,8,0,0">
                                         <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="Center" AlignItems="Center">
                                             
                                             <Border IsVisible="{Binding HasNuzulSebebi}" Stroke="{StaticResource MD3Outline}" StrokeThickness="1" Background="Transparent" Padding="12,8" Margin="4">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.ShowNuzulPopupCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" Tapped="OnPillButtonTapped" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                    <Label Text="ℹ️" FontSize="14" VerticalOptions="Center" />
                                                    <Label Text="Nüzul Sebebi" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                             </Border>

                                             <Border IsVisible="{Binding HasTefsir}" Stroke="{StaticResource MD3Outline}" StrokeThickness="1" Background="Transparent" Padding="12,8" Margin="4">
                                                <Border.StrokeShape><RoundRectangle CornerRadius="20" /></Border.StrokeShape>
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding BindingContext.ShowTefsirPopupCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" Tapped="OnPillButtonTapped" />
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                    <Label Text="📖" FontSize="14" VerticalOptions="Center" />
                                                    <Label Text="Tefsir" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>
                                            
                                        </FlexLayout>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </ScrollView>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
             </CarouselView>

             <Grid VerticalOptions="End" Margin="16,0,16,16" ColumnDefinitions="*,*" ColumnSpacing="12" ZIndex="10">
                <Grid.Triggers>
                    <DataTrigger TargetType="Grid" Binding="{Binding IsBusy}" Value="True">
                        <Setter Property="IsVisible" Value="False" />
                    </DataTrigger>
                </Grid.Triggers>
                <Button Grid.Column="0"
                        Text="← Önceki Sure"
                        Clicked="OnPrevSureClicked"
                        Style="{StaticResource FilledButton}"
                        Opacity="0.95">
                    <Button.Shadow><Shadow Brush="Black" Opacity="0.1" Offset="0,2" Radius="4"/></Button.Shadow>
                </Button>
                <Button Grid.Column="1"
                        Text="Sıradaki Sure →"
                        Clicked="OnNextSureClicked"
                        Style="{StaticResource FilledButton}"
                        Opacity="0.95">
                    <Button.Shadow><Shadow Brush="Black" Opacity="0.1" Offset="0,2" Radius="4"/></Button.Shadow>
                 </Button>
             </Grid>

         </Grid>

             <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="SurePickerOverlay" BackgroundColor="#AA000000" IsVisible="False" ZIndex="10">
                <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleSurePickerCommand}" /></Grid.GestureRecognizers>
                <Border VerticalOptions="End" HeightRequest="700" x:Name="SurePickerContainer" StrokeThickness="0" Padding="0" Background="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <VerticalStackLayout Grid.Row="0" Padding="20,14,20,8" Spacing="10">
                            <Grid HeightRequest="30" WidthRequest="200" BackgroundColor="Transparent" HorizontalOptions="Center">
                                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" Color="{StaticResource MD3Outline}" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                                <Grid.GestureRecognizers>
                                    <PanGestureRecognizer PanUpdated="OnSurePickerSheetPan" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Fihrist &amp; Gelişmiş Arama" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource MD3TextSecondary}" FontSize="18" WidthRequest="44" HeightRequest="44" Command="{Binding ToggleSurePickerCommand}" />
                            </Grid>
                        </VerticalStackLayout>
                        <Border Grid.Row="1" Margin="16,0,16,8" StrokeThickness="1" Stroke="{StaticResource MD3Outline}" Padding="4,0" Background="{AppThemeBinding Light=White, Dark={StaticResource MD3SurfaceVariantDark}}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                            <SearchBar Placeholder="Kuran'da Ara... (Adalet, Sabır)" Text="{Binding SurePickerSearch}" HeightRequest="44" />
                        </Border>
                        <CollectionView Grid.Row="2" ItemsSource="{Binding SurePickerItems}" SelectionMode="None">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Sure">
                                    <Border Margin="16,6,16,6" Padding="16,12" StrokeThickness="0">
                                         <Border.GestureRecognizers>
                                             <TapGestureRecognizer Command="{Binding BindingContext.JumpToSureCommand, Source={x:Reference page}}" CommandParameter="{Binding .}" />
                                         </Border.GestureRecognizers>
                                         <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3SurfaceContainerLow}, Dark={StaticResource MD3SurfaceVariantDark}}" />
                                                <Setter Property="StrokeShape">
                                                    <Setter.Value>
                                                        <RoundRectangle CornerRadius="16" />
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Border.Style>
                                        
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                                <Label Text="{Binding SureAdi}" FontAttributes="Bold" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                                                <Label Text="{Binding Tip, StringFormat='({0})'}" TextColor="{StaticResource MD3TextSecondary}" FontSize="13" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="1" Text="▶" VerticalOptions="Center" TextColor="{StaticResource MD3TextSecondary}" FontSize="12" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.Footer>
                                <BoxView HeightRequest="70" Color="Transparent" />
                            </CollectionView.Footer>
                        </CollectionView>
                        
                        <Border Grid.Row="3" 
                                Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" 
                                StrokeThickness="0" 
                                Padding="16,12"
                                ZIndex="5"
                                TranslationY="{Binding TranslationY, Source={x:Reference SurePickerContainer}, Converter={x:Static vm:NegativeValueConverter.Instance}}">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <Border Grid.Column="0" Style="{StaticResource M3PillSecondary}" HorizontalOptions="Center" WidthRequest="120">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleSurePickerCommand}" Tapped="OnPillButtonTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="İptal" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource M3PillPrimary}" HorizontalOptions="Center" WidthRequest="120">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ConfirmSureCommand}" Tapped="OnPillButtonTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Onayla" TextColor="{AppThemeBinding Light=White, Dark={StaticResource MD3OnPrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                 </Border>
             </Grid>

             <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="AyetPickerOverlay" BackgroundColor="#AA000000" IsVisible="False" ZIndex="15">
                <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleAyetPickerCommand}" /></Grid.GestureRecognizers>
                <Border x:Name="AyetPickerCard" VerticalOptions="Center" HorizontalOptions="Center" WidthRequest="320" HeightRequest="450" StrokeThickness="0" Padding="0" Background="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <VerticalStackLayout Grid.Row="0" Padding="20,16,20,12" Spacing="8">
                            <Label Text="Ayet Seç" Style="{StaticResource HeadlineMedium}" HorizontalOptions="Center" />
                            <Label Text="{Binding SureName}" Style="{StaticResource BodyMedium}" HorizontalOptions="Center" TextColor="{StaticResource MD3TextSecondary}" />
                             <BoxView HeightRequest="1" Color="{StaticResource MD3Outline}" Margin="0,8,0,0" />
                         </VerticalStackLayout>
                         
                         <CollectionView Grid.Row="1" ItemsSource="{Binding AvailableAyetNumbers}" Margin="16,0,16,16">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="5" VerticalItemSpacing="8" HorizontalItemSpacing="8" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:AyetNumberItem">
                                    <Border HeightRequest="44" WidthRequest="44" StrokeThickness="0" BackgroundColor="Transparent">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.JumpToAyetCommand, Source={x:Reference page}}" 
                                                                   CommandParameter="{Binding .}"
                                                                   Tapped="OnAyetNumberTapped" />
                                        </Border.GestureRecognizers>
                                        <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3SurfaceContainerLow}, Dark={StaticResource MD3SurfaceVariantDark}}" />
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3Primary}, Dark={StaticResource MD3PrimaryDark}}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Label Text="{Binding Number}" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold" FontSize="15">
                                            <Label.Style>
                                                <Style TargetType="Label">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                                                    <Style.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark={StaticResource MD3OnPrimaryDark}}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Label.Style>
                                        </Label>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Border Grid.Row="2" Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" StrokeThickness="0" Padding="16,12">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <Border Grid.Column="0" Style="{StaticResource M3PillSecondary}" HorizontalOptions="Center" WidthRequest="120">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ToggleAyetPickerCommand}" Tapped="OnPillButtonTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="İptal" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource M3PillPrimary}" HorizontalOptions="Center" WidthRequest="120">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ConfirmAyetCommand}" Tapped="OnPillButtonTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Onayla" TextColor="{AppThemeBinding Light=White, Dark={StaticResource MD3OnPrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                 </Border>
             </Grid>

             <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="SettingsSheetOverlay" BackgroundColor="#AA000000" IsVisible="False" ZIndex="20">
                <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleSettingsSheetCommand}" /></Grid.GestureRecognizers>
                <Border VerticalOptions="End" HeightRequest="700" x:Name="SettingsSheetContainer" StrokeThickness="0" Padding="0" Background="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                    <VerticalStackLayout Padding="20,14,20,32" Spacing="20">
                        <Grid HeightRequest="30" WidthRequest="200" BackgroundColor="Transparent" HorizontalOptions="Center">
                            <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" Color="{StaticResource MD3Outline}" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                            <Grid.GestureRecognizers>
                                <PanGestureRecognizer PanUpdated="OnSettingsSheetPan" />
                            </Grid.GestureRecognizers>
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                             <Label Text="Görünüm Ayarları" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                             <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource MD3TextSecondary}" FontSize="18" WidthRequest="44" HeightRequest="44" Command="{Binding ToggleSettingsSheetCommand}" />
                         </Grid>
                         <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                            <Button Text="A-" Command="{Binding DecreaseFontSizeCommand}" Style="{StaticResource TonalButton}" />
                            <Label Text="{Binding FontSizePercent}" VerticalOptions="Center" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=Black, Dark=White}" />
                            <Button Text="A+" Command="{Binding IncreaseFontSizeCommand}" Style="{StaticResource TonalButton}" />
                        </HorizontalStackLayout>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Disleksi Fontu" VerticalOptions="Center" Style="{StaticResource TitleMedium}" />
                            <Switch Grid.Column="1" IsToggled="{Binding UseDyslexicFont}" OnColor="{StaticResource MD3Primary}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="Yatay Okuma Modu" VerticalOptions="Center" Style="{StaticResource TitleMedium}" />
                            <Switch Grid.Column="1" IsToggled="{Binding UseHorizontalReadingMode}" OnColor="{StaticResource MD3Primary}" />
                        </Grid>

                        <Border Style="{StaticResource M3PillPrimary}" Margin="0,10,0,0" HorizontalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ApplySettingsCommand}" Tapped="OnPillButtonTapped" />
                            </Border.GestureRecognizers>
                            <Label Text="Ayarları Uygula" 
                                   TextColor="{AppThemeBinding Light=White, Dark={StaticResource MD3OnPrimaryDark}}" 
                                   FontAttributes="Bold" 
                                   HorizontalOptions="Center" 
                                   VerticalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>
                 </Border>
             </Grid>

             <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="BottomSheetOverlay" BackgroundColor="#AA000000" IsVisible="False" ZIndex="30">
                <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ToggleFilterSheetCommand}" /></Grid.GestureRecognizers>
                <Border VerticalOptions="End" HeightRequest="700" x:Name="BottomSheetContainer" StrokeThickness="0" Padding="0" Background="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,Auto,*,Auto">
                        <VerticalStackLayout Grid.Row="0" Padding="20,14,20,8" Spacing="10">
                            <Grid HeightRequest="30" WidthRequest="200" BackgroundColor="Transparent" HorizontalOptions="Center">
                                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" Color="{StaticResource MD3Outline}" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                                <Grid.GestureRecognizers>
                                    <PanGestureRecognizer PanUpdated="OnBottomSheetPan" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Tefsirleri Seç" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource MD3TextSecondary}" FontSize="18" WidthRequest="44" HeightRequest="44" Command="{Binding ToggleFilterSheetCommand}" />
                            </Grid>
                        </VerticalStackLayout>
                        <Border Grid.Row="1" Margin="16,0,16,8" StrokeThickness="1" Stroke="{StaticResource MD3Outline}" Padding="4,0" Background="{AppThemeBinding Light=White, Dark={StaticResource MD3SurfaceVariantDark}}">
                            <Border.StrokeShape><RoundRectangle CornerRadius="22"/></Border.StrokeShape>
                            <SearchBar Placeholder="Tefsir ara..." Text="{Binding FilterSearchText}" HeightRequest="44" />
                        </Border>
                        <CollectionView Grid.Row="2" ItemsSource="{Binding Translators}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:TranslatorFilterItem">
                                    <Border Margin="16,6,16,6" Padding="12,4,16,4" StrokeThickness="0">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding BindingContext.ToggleTranslatorSelectionCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3SurfaceContainerLow}, Dark={StaticResource MD3SurfaceVariantDark}}" />
                                                <Setter Property="StrokeShape">
                                                    <Setter.Value>
                                                        <RoundRectangle CornerRadius="16" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3Primary}}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" Color="{AppThemeBinding Light={StaticResource MD3Primary}, Dark={StaticResource MD3PrimaryDark}}" VerticalOptions="Center" InputTransparent="True" />
                                            <Label Grid.Column="1" Text="{Binding Name}" FontAttributes="Bold" FontSize="15" VerticalOptions="Center">
                                                <Label.Style>
                                                    <Style TargetType="Label">
                                                        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                                                        <Style.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                                                 <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnPrimary}}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Label.Style>
                                            </Label>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.Footer>
                                <BoxView HeightRequest="80" Color="Transparent" />
                            </CollectionView.Footer>
                        </CollectionView>
                        <Border Grid.Row="3" 
                                Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" 
                                StrokeThickness="0" 
                                Padding="16,12,16,24"
                                ZIndex="5"
                                TranslationY="{Binding TranslationY, Source={x:Reference BottomSheetContainer}, Converter={x:Static vm:NegativeValueConverter.Instance}}">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
                                <Border Grid.Column="0" Style="{StaticResource M3PillSecondary}" HorizontalOptions="Center" WidthRequest="120">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ClearTranslatorsCommand}" Tapped="OnPillButtonTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Temizle" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource M3PillPrimary}" HorizontalOptions="Center" WidthRequest="120">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ApplyFilterCommand}" Tapped="OnPillButtonTapped" />
                                    </Border.GestureRecognizers>
                                    <Label Text="Uygula" TextColor="{AppThemeBinding Light=White, Dark={StaticResource MD3OnPrimaryDark}}" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                 </Border>
             </Grid>

             <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="TefsirOverlay" BackgroundColor="#AA000000" IsVisible="False" ZIndex="40">
                <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ClosePopupsCommand}" /></Grid.GestureRecognizers>
                <Border VerticalOptions="End" HeightRequest="700" x:Name="TefsirSheetContainer" StrokeThickness="0" Padding="0" Background="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">
                    <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0" /></Border.StrokeShape>
                    <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*">
                        <VerticalStackLayout Grid.Row="0" Padding="20,14,20,8" Spacing="10">
                            <Grid HeightRequest="30" WidthRequest="200" BackgroundColor="Transparent" HorizontalOptions="Center">
                                <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" Color="{StaticResource MD3Outline}" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                                <Grid.GestureRecognizers>
                                    <PanGestureRecognizer PanUpdated="OnTefsirSheetPan" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Açıklama (Tefsir)" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource MD3TextSecondary}" FontSize="18" WidthRequest="44" HeightRequest="44" Command="{Binding ClosePopupsCommand}" />
                            </Grid>
                        </VerticalStackLayout>
                        <ScrollView x:Name="TefsirScrollView" Grid.Row="1" Padding="20,0,20,20" VerticalOptions="Fill">
                            <StackLayout BindableLayout.ItemsSource="{Binding SelectedAyetForPopup.Mealler}" Spacing="16">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:MealWithAciklama">
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="{Binding YazarAdi, StringFormat='{0} Açıklaması'}" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource MD3Primary}, Dark={StaticResource MD3PrimaryDark}}" />
                                            <Label Text="{Binding DisplayAciklamaMetni}" FontFamily="{DynamicResource AppFontFamily}" FontSize="{Binding BindingContext.AciklamaFontSize, Source={x:Reference page}}" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" LineBreakMode="WordWrap">
                                                <Label.Style>
                                                    <Style TargetType="Label">
                                                        <Style.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding HasAciklama}" Value="False">
                                                                <Setter Property="FontAttributes" Value="Italic" />
                                                                <Setter Property="TextColor" Value="{StaticResource MD3TextMuted}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Label.Style>
                                            </Label>
                                            <BoxView HeightRequest="1" Color="{StaticResource MD3Outline}" Margin="0,8,0,0" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </StackLayout>
                        </ScrollView>
                    </Grid>
                 </Border>
             </Grid>
 
              <Grid Grid.Row="0" Grid.RowSpan="3" x:Name="NuzulOverlay" BackgroundColor="#AA000000" IsVisible="False" ZIndex="40">
                 <Grid.GestureRecognizers><TapGestureRecognizer Command="{Binding ClosePopupsCommand}" /></Grid.GestureRecognizers>
                 <Border VerticalOptions="End" HeightRequest="700" x:Name="NuzulSheetContainer" StrokeThickness="0" Padding="0" Background="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">
                     <Border.StrokeShape><RoundRectangle CornerRadius="24,24,0,0" /></Border.StrokeShape>
                     <Border.GestureRecognizers><TapGestureRecognizer /></Border.GestureRecognizers>
                     <Grid RowDefinitions="Auto,*">
                         <VerticalStackLayout Grid.Row="0" Padding="20,14,20,8" Spacing="10">
                             <Grid HeightRequest="30" WidthRequest="200" BackgroundColor="Transparent" HorizontalOptions="Center">
                                 <BoxView WidthRequest="40" HeightRequest="4" CornerRadius="2" Color="{StaticResource MD3Outline}" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True" />
                                 <Grid.GestureRecognizers>
                                     <PanGestureRecognizer PanUpdated="OnNuzulSheetPan" />
                                 </Grid.GestureRecognizers>
                             </Grid>
                              <Grid ColumnDefinitions="*,Auto">
                                  <Label Text="İniş Sebebi (Esbab-ı Nüzul)" Style="{StaticResource HeadlineMedium}" VerticalOptions="Center" />
                                  <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent" TextColor="{StaticResource MD3TextSecondary}" FontSize="18" WidthRequest="44" HeightRequest="44" Command="{Binding ClosePopupsCommand}" />
                              </Grid>
                          </VerticalStackLayout>
                          <ScrollView x:Name="NuzulScrollView" Grid.Row="1" Padding="20,0,20,20" VerticalOptions="Fill">
                              <Label Text="{Binding SelectedAyetForPopup.NuzulSebebiText}" FontFamily="{DynamicResource AppFontFamily}" FontSize="{Binding BindingContext.AciklamaFontSize, Source={x:Reference page}}" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" LineBreakMode="WordWrap" />
                          </ScrollView>
                    </Grid>
                </Border>
            </Grid>
    </Grid>
</ContentPage>
