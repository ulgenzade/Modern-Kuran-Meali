<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KuranMealApp.ViewModels"
             x:Class="KuranMealApp.Views.AyarlarPage"
             x:DataType="vm:AyarlarViewModel"
             Title="Ayarlar"
             BackgroundColor="{AppThemeBinding Light={StaticResource MD3Surface}, Dark={StaticResource MD3SurfaceDark}}">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3PrimaryContainer}, Dark={StaticResource MD3SurfaceDark}}" Padding="16,20,16,20">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,24,24" />
            </Border.StrokeShape>
            
            <VerticalStackLayout Spacing="6">
                <Label Text="Uygulama Ayarları"
                       Style="{StaticResource HeadlineMedium}"
                       TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}"
                       FontAttributes="Bold" />
                <Label Text="Okuma deneyiminizi kişiselleştirin."
                       Style="{StaticResource BodyMedium}"
                       TextColor="{AppThemeBinding Light={StaticResource MD3OnPrimaryContainer}, Dark={StaticResource MD3OnSurfaceDark}}" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" Margin="16,12,16,16">
            <VerticalStackLayout Spacing="20">
                
                <Label Text="Görünüm ve Okuma Ayarları" Style="{StaticResource LabelMedium}" TextColor="{StaticResource MD3Primary}" Margin="4,0,0,2" />
                <VerticalStackLayout Spacing="12">
                    <Border StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3SurfaceContainerLow}, Dark={StaticResource MD3CardDark}}" Padding="16">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="Karanlık Mod" Style="{StaticResource TitleMedium}" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                                <Label Text="Göz yormayan koyu tema." Style="{StaticResource BodySmall}" TextColor="{StaticResource MD3TextSecondary}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding IsDarkMode}" OnColor="{StaticResource MD3Primary}" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <Border StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3SurfaceContainerLow}, Dark={StaticResource MD3CardDark}}" Padding="16">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="Disleksi Desteği" Style="{StaticResource TitleMedium}" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                                <Label Text="Özel OpenDyslexic yazı tipi." Style="{StaticResource BodySmall}" TextColor="{StaticResource MD3TextSecondary}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="1" IsToggled="{Binding UseDyslexicFont}" OnColor="{StaticResource MD3Primary}" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                </VerticalStackLayout>

                <Label Text="Uygulama Hakkında" FontAttributes="Bold" FontSize="15" TextColor="{StaticResource MD3Primary}" Margin="4,0,0,2" />
                <Border StrokeThickness="0" Background="{AppThemeBinding Light={StaticResource MD3SurfaceContainerLow}, Dark={StaticResource MD3CardDark}}" Padding="16">
                    <Border.StrokeShape><RoundRectangle CornerRadius="20"/></Border.StrokeShape>
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Text="Uygulama Sürümü" Style="{StaticResource TitleMedium}" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource MD3TextPrimary}, Dark={StaticResource MD3TextPrimaryDark}}" />
                            <Label Grid.Column="1" Text="v1.3.4" FontAttributes="Bold" TextColor="{StaticResource MD3TextSecondary}" FontSize="14" />
                        </Grid>
                </Border>

                <Border Style="{StaticResource M3PillPrimary}" Margin="0,10,0,30" HorizontalOptions="Center">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ApplyCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="Uygula" 
                           TextColor="{AppThemeBinding Light=White, Dark={StaticResource MD3OnPrimaryDark}}" 
                           FontAttributes="Bold" 
                           HorizontalOptions="Center" 
                           VerticalOptions="Center" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>